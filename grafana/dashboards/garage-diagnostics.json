    {
      "id": 14,
      "type": "table",
      "title": "Důvody resetů (AVR MCUSR)",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "grafana-postgresql-heater-diag"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 29
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left"
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "Unknown",
                  "index": 0
                },
                "1": {
                  "text": "PowerOn (PORF)",
                  "index": 1
                },
                "2": {
                  "text": "External (EXTRF)",
                  "index": 2
                },
                "4": {
                  "text": "BrownOut (BORF)",
                  "index": 3
                },
                "8": {
                  "text": "Watchdog (WDRF)",
                  "index": 4
                },
                "16": {
                  "text": "JTAG (JTRF)",
                  "index": 5
                }
              }
            }
          ]
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Reason"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "0": {
                        "text": "Unknown",
                        "index": 0
                      },
                      "1": {
                        "text": "PowerOn (PORF)",
                        "index": 1
                      },
                      "2": {
                        "text": "External (EXTRF)",
                        "index": 2
                      },
                      "4": {
                        "text": "BrownOut (BORF)",
                        "index": 3
                      },
                      "8": {
                        "text": "Watchdog (WDRF)",
                        "index": 4
                      },
                      "16": {
                        "text": "JTAG (JTRF)",
                        "index": 5
                      }
                    }
                  }
                ]
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT reset_reason AS \"Reason\", count(*) AS \"Počet\", max(timestamp) AS \"Naposledy\" FROM garage_diagnostics WHERE $__timeFilter(timestamp) GROUP BY reset_reason ORDER BY count(*) DESC"
        }
      ]
    },
