{
  "title": "Device Diagnostics",
  "uid": "device-diagnostics",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "tags": ["diagnostics", "iot"],
  "timezone": "browser",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "device",
        "label": "Device",
        "type": "custom",
        "query": "heater,ls_sensor,garage",
        "current": {
          "selected": false,
          "text": "heater",
          "value": "heater"
        },
        "options": [
          { "text": "heater", "value": "heater", "selected": true },
          { "text": "ls_sensor", "value": "ls_sensor", "selected": false },
          { "text": "garage", "value": "garage", "selected": false }
        ],
        "hide": 0,
        "includeAll": false,
        "multi": false
      },
      {
        "name": "mqtt_col",
        "label": "MQTT column",
        "type": "query",
        "datasource": { "type": "grafana-postgresql-datasource", "uid": "grafana-postgresql-heater-diag" },
        "query": "SELECT CASE WHEN '$device' = 'ls_sensor' THEN 'mqtt_fail_count' ELSE 'mqtt_reconnects' END AS col",
        "refresh": 1,
        "hide": 2,
        "multi": false,
        "includeAll": false,
        "regex": "",
        "sort": 0
      },
      {
        "name": "interval_min",
        "label": "Expected interval (min)",
        "type": "query",
        "datasource": { "type": "grafana-postgresql-datasource", "uid": "grafana-postgresql-heater-diag" },
        "query": "SELECT CASE WHEN '$device' = 'garage' THEN 15 ELSE 5 END AS minutes",
        "refresh": 1,
        "hide": 2,
        "multi": false,
        "includeAll": false,
        "regex": "",
        "sort": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Last seen (× interval)",
      "description": "How many expected intervals have passed since the latest record. Expected interval is 5 min for heater/ls_sensor, 15 min for garage. Yellow at 1.5×, red at 3× (device offline).",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "grafana-postgresql-heater-diag" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1.5 },
              { "color": "red", "value": 3 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT EXTRACT(EPOCH FROM (now() - max(timestamp))) / 60.0 / ${interval_min}::float AS \"intervals\" FROM ${device}_diagnostics"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Uptime",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "grafana-postgresql-heater-diag" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "m" }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT timestamp AS time, uptime_minutes AS value FROM ${device}_diagnostics WHERE $__timeFilter(timestamp) ORDER BY timestamp"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Free RAM",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "grafana-postgresql-heater-diag" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "green", "value": 400 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT timestamp AS time, free_ram AS value FROM ${device}_diagnostics WHERE $__timeFilter(timestamp) ORDER BY timestamp"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Loop max",
      "description": "Watchdog timeout is 8000 ms. Yellow >1 s (12.5% WDT), orange >2 s (25%), red >4 s (50% — imminent WDT reset risk).",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "grafana-postgresql-heater-diag" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "max": 8000,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "orange", "value": 2000 },
              { "color": "red", "value": 4000 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["max"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT timestamp AS time, loop_max_ms AS value FROM ${device}_diagnostics WHERE $__timeFilter(timestamp) ORDER BY timestamp"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Free RAM over time",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "grafana-postgresql-heater-diag" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "green", "value": 400 }
            ]
          }
        }
      },
      "options": { "tooltip": { "mode": "single" } },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT timestamp AS time, free_ram AS \"Free RAM\" FROM ${device}_diagnostics WHERE $__timeFilter(timestamp) ORDER BY timestamp"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Loop max ms over time",
      "description": "Watchdog timeout is 8000 ms. Yellow >1 s (12.5% WDT), orange >2 s (25%), red >4 s (50% — imminent WDT reset risk).",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "grafana-postgresql-heater-diag" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "max": 8000,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "orange", "value": 2000 },
              { "color": "red", "value": 4000 }
            ]
          }
        }
      },
      "options": { "tooltip": { "mode": "single" } },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT timestamp AS time, loop_max_ms AS \"Loop max\" FROM ${device}_diagnostics WHERE $__timeFilter(timestamp) ORDER BY timestamp"
        }
      ]
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Uptime (drops = reboot)",
      "description": "Drops in uptime indicate the device rebooted.",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "grafana-postgresql-heater-diag" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": {
        "defaults": {
          "unit": "m",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 5 }
        }
      },
      "options": { "tooltip": { "mode": "single" } },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT timestamp AS time, uptime_minutes AS \"Uptime\" FROM ${device}_diagnostics WHERE $__timeFilter(timestamp) ORDER BY timestamp"
        }
      ]
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "WiFi reconnects (counter, resets on reboot)",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "grafana-postgresql-heater-diag" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 5 }
        }
      },
      "options": { "tooltip": { "mode": "single" } },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT timestamp AS time, wifi_reconnects AS \"WiFi reconnects\" FROM ${device}_diagnostics WHERE $__timeFilter(timestamp) ORDER BY timestamp"
        }
      ]
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "MQTT reconnects / failures (counter, resets on reboot)",
      "description": "Column auto-switches: heater & garage use mqtt_reconnects, ls_sensor uses mqtt_fail_count.",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "grafana-postgresql-heater-diag" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 5 }
        }
      },
      "options": { "tooltip": { "mode": "single" } },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT timestamp AS time, ${mqtt_col} AS \"MQTT\" FROM ${device}_diagnostics WHERE $__timeFilter(timestamp) ORDER BY timestamp"
        }
      ]
    },
    {
      "id": 23,
      "type": "timeseries",
      "title": "WiFi RSSI over time",
      "description": "Received Signal Strength Indicator in dBm. Green > -65, yellow -75…-65, orange -85…-75, red < -85.",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "grafana-postgresql-heater-diag" },
      "gridPos": { "h": 8, "w": 18, "x": 0, "y": 28 },
      "fieldConfig": {
        "defaults": {
          "unit": "dBm",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": -85 },
              { "color": "yellow", "value": -75 },
              { "color": "green", "value": -65 }
            ]
          }
        }
      },
      "options": { "tooltip": { "mode": "single" } },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT timestamp AS time, rssi AS \"RSSI\" FROM ${device}_diagnostics WHERE $__timeFilter(timestamp) AND rssi IS NOT NULL ORDER BY timestamp"
        }
      ]
    },
    {
      "id": 24,
      "type": "stat",
      "title": "Current RSSI",
      "description": "Latest RSSI reading. Green > -65, yellow -75…-65, orange -85…-75, red < -85.",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "grafana-postgresql-heater-diag" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 28 },
      "fieldConfig": {
        "defaults": {
          "unit": "dBm",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": -85 },
              { "color": "yellow", "value": -75 },
              { "color": "green", "value": -65 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT timestamp AS time, rssi AS value FROM ${device}_diagnostics WHERE $__timeFilter(timestamp) AND rssi IS NOT NULL ORDER BY timestamp"
        }
      ]
    },
    {
      "id": 30,
      "type": "table",
      "title": "Reset reason breakdown",
      "description": "AVR MCUSR bits: 1=PowerOn, 2=External, 4=BrownOut, 8=Watchdog, 16=JTAG",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "grafana-postgresql-heater-diag" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 36 },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "left" },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "Unknown", "index": 0 },
                "1": { "text": "PowerOn (PORF)", "index": 1 },
                "2": { "text": "External (EXTRF)", "index": 2 },
                "4": { "text": "BrownOut (BORF)", "index": 3 },
                "8": { "text": "Watchdog (WDRF)", "index": 4 },
                "16": { "text": "JTAG (JTRF)", "index": 5 }
              }
            }
          ]
        }
      },
      "options": { "showHeader": true },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT reset_reason AS \"Reason\", count(*) AS \"Count\", max(timestamp) AS \"Last seen\" FROM ${device}_diagnostics WHERE $__timeFilter(timestamp) GROUP BY reset_reason ORDER BY count(*) DESC"
        }
      ]
    },
    {
      "id": 31,
      "type": "stat",
      "title": "Reboots in window",
      "description": "Count of uptime drops (where current uptime < previous uptime) within the dashboard time range.",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "grafana-postgresql-heater-diag" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 36 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT count(*) AS reboots FROM (SELECT uptime_minutes, LAG(uptime_minutes) OVER (ORDER BY timestamp) AS prev FROM ${device}_diagnostics WHERE $__timeFilter(timestamp)) t WHERE prev IS NOT NULL AND uptime_minutes < prev"
        }
      ]
    },
    {
      "id": 32,
      "type": "stat",
      "title": "Records collected",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "grafana-postgresql-heater-diag" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 36 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT count(*) AS records FROM ${device}_diagnostics WHERE $__timeFilter(timestamp)"
        }
      ]
    },
    {
      "id": 40,
      "type": "row",
      "title": "Garage only — door cycles",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 44 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 41,
      "type": "timeseries",
      "title": "Door cycles (counter)",
      "description": "Hardcoded to garage_diagnostics — independent of $device.",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "grafana-postgresql-heater-diag" },
      "gridPos": { "h": 8, "w": 18, "x": 0, "y": 45 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10 }
        }
      },
      "options": { "tooltip": { "mode": "single" } },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT timestamp AS time, door_cycles AS \"Door cycles\" FROM garage_diagnostics WHERE $__timeFilter(timestamp) ORDER BY timestamp"
        }
      ]
    },
    {
      "id": 42,
      "type": "stat",
      "title": "Door cycles total (latest)",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "grafana-postgresql-heater-diag" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 45 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT timestamp AS time, door_cycles AS value FROM garage_diagnostics ORDER BY timestamp DESC LIMIT 1"
        }
      ]
    }
  ]
}
