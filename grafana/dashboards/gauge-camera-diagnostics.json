          "rawSql": "WITH c AS (SELECT * FROM camera_config WHERE gauge_id::text = '$gauge' ORDER BY timestamp DESC LIMIT 1)\nSELECT 1 AS ord, 'Framesize' AS \"Nastavení\", CASE framesize WHEN 11 THEN 'SVGA (11)' ELSE framesize::text END AS \"Hodnota\" FROM c\nUNION ALL SELECT 2, 'Quality (0-63, nižší=lepší)', quality::text FROM c\nUNION ALL SELECT 3, 'AEC value (expozice)', aec_value::text FROM c\nUNION ALL SELECT 4, 'Exposure ctrl (AEC)', CASE exposure_ctrl WHEN 1 THEN 'on' ELSE 'off' END FROM c\nUNION ALL SELECT 5, 'Gain ctrl (AGC)', CASE gain_ctrl WHEN 1 THEN 'on' ELSE 'off' END FROM c\nUNION ALL SELECT 6, 'AGC gain', agc_gain::text FROM c\nUNION ALL SELECT 7, 'AE level', ae_level::text FROM c\nUNION ALL SELECT 8, 'Jas (brightness)', brightness::text FROM c\nUNION ALL SELECT 9, 'Kontrast', contrast::text FROM c\nUNION ALL SELECT 10, 'Sytost (saturation)', saturation::text FROM c\nUNION ALL SELECT 11, 'AWB (whitebal)', CASE whitebal WHEN 1 THEN 'on' ELSE 'off' END FROM c\nUNION ALL SELECT 12, 'AWB gain', CASE awb_gain WHEN 1 THEN 'on' ELSE 'off' END FROM c\nUNION ALL SELECT 13, 'WB mode', CASE wb_mode WHEN 0 THEN 'auto' WHEN 1 THEN 'sunny' WHEN 2 THEN 'cloudy' WHEN 3 THEN 'office' WHEN 4 THEN 'home' ELSE wb_mode::text END FROM c\nUNION ALL SELECT 14, 'Special effect', special_effect::text FROM c\nUNION ALL SELECT 15, 'H-mirror', CASE hmirror WHEN 1 THEN 'on' ELSE 'off' END FROM c\nUNION ALL SELECT 16, 'V-flip', CASE vflip WHEN 1 THEN 'on' ELSE 'off' END FROM c\nUNION ALL SELECT 17, 'AEC2 (noční DSP)', CASE aec2 WHEN 1 THEN 'on' ELSE 'off' END FROM c\nUNION ALL SELECT 18, 'Gainceiling', CASE gainceiling WHEN 0 THEN '2x' WHEN 1 THEN '4x' WHEN 2 THEN '8x' WHEN 3 THEN '16x' WHEN 4 THEN '32x' WHEN 5 THEN '64x' WHEN 6 THEN '128x' ELSE gainceiling::text END FROM c\nUNION ALL SELECT 19, 'DCW (downsize/crop)', CASE dcw WHEN 1 THEN 'on' ELSE 'off' END FROM c\nUNION ALL SELECT 20, 'BPC (vadné pixely)', CASE bpc WHEN 1 THEN 'on' ELSE 'off' END FROM c\nUNION ALL SELECT 21, 'WPC (bílé pixely)', CASE wpc WHEN 1 THEN 'on' ELSE 'off' END FROM c\nUNION ALL SELECT 22, 'Raw GMA (gamma)', CASE raw_gma WHEN 1 THEN 'on' ELSE 'off' END FROM c\nUNION ALL SELECT 23, 'LENC (vinětace)', CASE lenc WHEN 1 THEN 'on' ELSE 'off' END FROM c\nORDER BY ord"
        }
      ],
      "description": "Skutečný stav senzoru (sensor_t.status), ne to, co firmware chtěl nastavit."
