{
  "title": "Gauge Camera (WaterSensor)",
  "uid": "gauge-camera-diagnostics",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "tags": [
    "diagnostics",
    "iot",
    "watersensor",
    "gauge"
  ],
  "timezone": "browser",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "gauge",
        "label": "Gauge",
        "type": "query",
        "datasource": {
          "type": "grafana-postgresql-datasource",
          "uid": "grafana-postgresql-heater-diag"
        },
        "query": "SELECT DISTINCT gauge_id FROM (SELECT gauge_id FROM device_diagnostics UNION ALL SELECT gauge_id FROM file_diagnostics UNION ALL SELECT gauge_id FROM transfer_diagnostics UNION ALL SELECT gauge_id FROM camera_config UNION ALL SELECT 0) q ORDER BY gauge_id",
        "refresh": 1,
        "hide": 0,
        "multi": false,
        "includeAll": false,
        "regex": "",
        "sort": 3
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Zařízení – stav (ESP32-CAM)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Naposledy viděno (× interval)",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "grafana-postgresql-heater-diag"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1.5
              },
              {
                "color": "red",
                "value": 3
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT EXTRACT(EPOCH FROM (now() - max(timestamp))) / 60.0 / 5.0 AS intervals FROM device_diagnostics WHERE gauge_id::text = '$gauge'"
        }
      ],
      "description": "Kolik očekávaných intervalů (5 min) uběhlo od posledního záznamu. Žlutá 1.5×, červená 3× (offline)."
    },
