        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT count(*) AS reboots FROM (SELECT uptime_seconds, LAG(uptime_seconds) OVER (ORDER BY timestamp) AS prev FROM device_diagnostics WHERE gauge_id::text = '$gauge' AND $__timeFilter(timestamp)) t WHERE prev IS NOT NULL AND uptime_seconds < prev"
        }
      ],
      "description": "Počet poklesů uptime (= rebootů) v okně."
    },
